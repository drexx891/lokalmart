generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Tabel untuk menyimpan data Pengguna (Pembeli & Penjual)
model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String?
  role      String   @default("user") // Bisa "user" atau "admin"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Tabel untuk menyimpan data Produk UMKM
model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Int
  stock       Int      @default(0)
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
